<component type="desktop-application">
  <id>com.topi.YapCap</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MPL-2.0</project_license>
  <name>YapCap</name>
  <summary>COSMIC panel applet for Codex, Claude Code, and Cursor usage</summary>
  <developer id="com.topi">
    <name>Topi Csarno</name>
  </developer>
  <description>
    <p>
      YapCap is a COSMIC panel applet that shows local usage state for Codex,
      Claude Code, and Cursor accounts without telemetry, cloud sync, or a
      YapCap service account.
    </p>
    <p>
      The app stores provider account state locally and calls provider APIs
      directly over HTTPS.
    </p>
  </description>
  <icon type="remote" width="64" height="64" scale="1">
    https://github.com/TopiCsarno/yapcap/raw/main/resources/icon.svg
  </icon>
  <url type="homepage">https://github.com/TopiCsarno/yapcap</url>
  <url type="vcs-browser">https://github.com/TopiCsarno/yapcap</url>
  <launchable type="desktop-id">com.topi.YapCap.desktop</launchable>
  <provides>
    <binary>yapcap</binary>
  </provides>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
